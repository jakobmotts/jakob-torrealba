rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required, immutable)
    //   - trainingBlock: string (required, 'strength' or 'growth')
    //   - currentSplitIndex: number (required)
    //   - targetCalories: number (optional)
    //   - targetProtein: number (optional)
    //   - targetCarbs: number (optional)
    //   - targetFats: number (optional)
    //   - pushNotificationsEnabled: boolean (optional)
    //
    // Collection: dailyLogs
    // Document ID: {userId}_{date}
    // Fields:
    //   - uid: string (required, immutable)
    //   - date: string (required, YYYY-MM-DD)
    //   - weight: number (optional)
    //   - caloriesConsumed: number (optional)
    //   - proteinConsumed: number (optional)
    //   - carbsConsumed: number (optional)
    //   - fatsConsumed: number (optional)
    //
    // Collection: workoutLogs
    // Document ID: {userId}_{date}
    // Fields:
    //   - uid: string (required, immutable)
    //   - date: string (required, YYYY-MM-DD)
    //   - splitName: string (required)
    //   - exercises: list (optional)
    //
    // Collection: futureEvents
    // Document ID: {eventId}
    // Fields:
    //   - uid: string (required, immutable)
    //   - date: string (required, YYYY-MM-DD)
    //   - title: string (required)
    //   - description: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidDateString(dateStr) {
      return dateStr is string && dateStr.matches("^\\d{4}-\\d{2}-\\d{2}$");
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.uid is string &&
             data.trainingBlock in ['strength', 'growth'] &&
             data.currentSplitIndex is number &&
             (!('targetCalories' in data) || data.targetCalories is number) &&
             (!('targetProtein' in data) || data.targetProtein is number) &&
             (!('targetCarbs' in data) || data.targetCarbs is number) &&
             (!('targetFats' in data) || data.targetFats is number) &&
             (!('pushNotificationsEnabled' in data) || data.pushNotificationsEnabled is bool) &&
             (!('goals' in data) || data.goals is list) &&
             (!('scheduleTemplate' in data) || data.scheduleTemplate is list) &&
             (!('macroOffsets' in data) || data.macroOffsets is map) &&
             (!('currentGoal' in data) || data.currentGoal in ['cut', 'maintain', 'bulk']) &&
             (!('targetWeight' in data) || data.targetWeight is number) &&
             (!('targetWeightDate' in data) || data.targetWeightDate is string) &&
             (!('trainingMealPlan' in data) || data.trainingMealPlan is list) &&
             (!('restMealPlan' in data) || data.restMealPlan is list) &&
             (!('workoutSplit' in data) || data.workoutSplit is list);
    }

    function isValidDailyLog(data) {
      return data.uid is string &&
             isValidDateString(data.date) &&
             (!('weight' in data) || data.weight is number) &&
             (!('caloriesConsumed' in data) || data.caloriesConsumed is number) &&
             (!('proteinConsumed' in data) || data.proteinConsumed is number) &&
             (!('carbsConsumed' in data) || data.carbsConsumed is number) &&
             (!('fatsConsumed' in data) || data.fatsConsumed is number) &&
             (!('meals' in data) || data.meals is map) &&
             (!('checkInPhotos' in data) || data.checkInPhotos is list) &&
             (!('notes' in data) || data.notes is string) &&
             (!('tasks' in data) || data.tasks is map) &&
             (!('dailyKpis' in data) || data.dailyKpis is map) &&
             (!('completedBlocks' in data) || data.completedBlocks is map);
    }

    function isValidWorkoutLog(data) {
      return data.uid is string &&
             isValidDateString(data.date) &&
             data.splitName is string && data.splitName.size() < 50 &&
             (!('exercises' in data) || data.exercises is list) &&
             (!('loggedExercises' in data) || data.loggedExercises is map);
    }

    function isValidFutureEvent(data) {
      return data.uid is string &&
             isValidDateString(data.date) &&
             (!('id' in data) || data.id is string) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             (!('description' in data) || data.description is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && hasRequiredFields(['uid', 'trainingBlock', 'currentSplitIndex']) && isValidUser(request.resource.data) && uidUnchanged();
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && uidNotModified();
    }

    match /dailyLogs/{logId} {
      allow read: if isAuthenticated() && (logId.matches('^' + request.auth.uid + '_.*$') || resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && hasRequiredFields(['uid', 'date']) && isValidDailyLog(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidDailyLog(request.resource.data) && uidNotModified();
    }

    match /workoutLogs/{logId} {
      allow read: if isAuthenticated() && (logId.matches('^' + request.auth.uid + '_.*$') || resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && hasRequiredFields(['uid', 'date', 'splitName']) && isValidWorkoutLog(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidWorkoutLog(request.resource.data) && uidNotModified();
    }

    match /futureEvents/{eventId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && hasRequiredFields(['uid', 'date', 'title']) && isValidFutureEvent(request.resource.data) && uidUnchanged();
      allow update: if isDocOwner() && isValidFutureEvent(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }
  }
}
